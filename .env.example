# =============================================================================
# AIRP — .env.example
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked REQUIRED
#   3. Never commit .env — it is in .gitignore
#   4. This file (.env.example) IS committed — it documents all variables
#
# SECTIONS:
#   1. Application
#   2. LLM Provider (Claude / Anthropic)
#   3. Observability (LangSmith)
#   4. Database (PostgreSQL — Neon)
#   5. Cache (Redis — Upstash)
#   6. Vector Store (ChromaDB)
#   7. Authentication (Clerk)
#   8. External Data APIs
#   9. Frontend (Vite)
#  10. Feature Flags
# =============================================================================


# ── 1. Application ────────────────────────────────────────────────────────────

# Runtime environment. Controls logging verbosity, error detail, and
# whether debug endpoints are exposed.
# Type    : string
# Values  : development | test | staging | production
# Default : development
# Required: yes
ENVIRONMENT=development

# Python logging level for the FastAPI application.
# Type    : string
# Values  : DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default : INFO (use DEBUG locally for verbose output)
# Required: no
LOG_LEVEL=INFO

# Comma-separated list of origins allowed to make cross-origin requests.
# Add your Vercel preview URL here when testing deployed frontend.
# Type    : string (comma-separated URLs, no trailing slashes)
# Example : http://localhost:5173,https://airp.vercel.app
# Required: yes
CORS_ORIGINS=http://localhost:5173

# Secret key used to sign JWT tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Type    : string (64-char hex)
# Required: yes (Phase 5 — FastAPI auth)
SECRET_KEY=replace-with-64-char-hex-secret-generated-locally

# JWT token expiry in minutes.
# Type    : integer
# Default : 60 (1 hour)
# Required: no
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ── 2. LLM Provider (Claude / Anthropic) ─────────────────────────────────────

# Anthropic API key — backbone for all 8 agents.
# Get it at: https://console.anthropic.com/settings/keys
# Format  : sk-ant-api03-...
# Type    : string
# Required: yes
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-key

# Claude model to use for all agents.
# Changing this one variable swaps the model for every agent simultaneously.
# Type    : string
# Default : claude-sonnet-4-20250514 (balance of speed and quality)
# Options : claude-opus-4-20250514 | claude-sonnet-4-20250514 | claude-haiku-4-20250514
# Required: no
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Maximum tokens per agent LLM call. Increase for longer Investment Memos.
# Type    : integer
# Default : 4096
# Required: no
ANTHROPIC_MAX_TOKENS=4096


# ── 3. Observability (LangSmith) ─────────────────────────────────────────────

# LangSmith API key — traces every agent call with latency and token data.
# Get it at: https://smith.langchain.com/settings
# Format  : ls__...
# Type    : string
# Required: yes (traces are disabled if absent but recommended)
LANGSMITH_API_KEY=ls__replace-with-your-key

# Enables LangChain/LangGraph tracing to LangSmith.
# Type    : boolean string
# Default : true
# Required: no (set to false to disable tracing locally)
LANGCHAIN_TRACING_V2=true

# LangSmith project name. Traces are grouped under this project.
# Use different names per environment (airp-dev, airp-staging, airp-prod).
# Type    : string
# Required: no (defaults to "default" if absent)
LANGCHAIN_PROJECT=airp-dev

# LangSmith endpoint. Only change if using a self-hosted LangSmith instance.
# Type    : string (URL)
# Default : https://api.smith.langchain.com
# Required: no
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# ── 4. Database (PostgreSQL — Neon) ──────────────────────────────────────────

# Primary database connection string.
# Local Docker  : postgresql+asyncpg://airp:airp@localhost:5432/airp
# Neon (cloud)  : postgresql+asyncpg://user:password@ep-xxx.neon.tech/airp?sslmode=require
# Test          : postgresql+asyncpg://airp:airp@localhost:5432/airp_test
# Get Neon URL  : https://console.neon.tech → your project → Connection Details
# Type    : string (SQLAlchemy async URL)
# Required: yes
DATABASE_URL=postgresql+asyncpg://airp:airp@localhost:5432/airp

# Separate test database URL — used when ENVIRONMENT=test.
# Must point to a different database than DATABASE_URL to prevent
# tests from touching development data.
# Type    : string (SQLAlchemy async URL)
# Required: yes (for running pytest)
DATABASE_TEST_URL=postgresql+asyncpg://airp:airp@localhost:5432/airp_test

# SQLAlchemy connection pool size.
# Type    : integer
# Default : 5
# Required: no
DB_POOL_SIZE=5

# Maximum overflow connections above pool size.
# Type    : integer
# Default : 10
# Required: no
DB_MAX_OVERFLOW=10


# ── 5. Cache (Redis — Upstash) ────────────────────────────────────────────────

# Redis connection URL.
# Local Docker   : redis://localhost:6379
# Upstash (cloud): rediss://default:password@host.upstash.io:6379
# Get Upstash URL: https://console.upstash.com → your database → REST API
# Type    : string (URL)
# Required: yes
REDIS_URL=redis://localhost:6379

# Upstash Redis REST token — only required when using Upstash cloud.
# Not needed for local Docker Redis.
# Get it at: https://console.upstash.com → your database → REST API → token
# Type    : string
# Required: only for Upstash cloud (not local Docker)
REDIS_TOKEN=replace-with-upstash-token-if-using-cloud

# Cache TTLs in seconds — controls how long API responses are cached.
# Reducing these increases API call frequency (watch free tier limits).
# Type    : integer (seconds)
# Required: no
CACHE_TTL_STOCK=900          # 15 minutes — stock prices change frequently
CACHE_TTL_NEWS=3600          # 1 hour — news doesn't change that fast
CACHE_TTL_MACRO=86400        # 24 hours — macro data changes rarely
CACHE_TTL_FUNDAMENTALS=3600  # 1 hour — financial statements are stable


# ── 6. Vector Store (ChromaDB) ────────────────────────────────────────────────

# ChromaDB host. Points to the Docker container in local dev.
# Type    : string (hostname)
# Default : localhost
# Required: no
CHROMA_HOST=localhost

# ChromaDB port. Default ChromaDB port.
# Type    : integer
# Default : 8001 (mapped from container's 8000 in docker-compose)
# Required: no
CHROMA_PORT=8001

# ChromaDB collection name for storing news and earnings embeddings.
# Type    : string
# Default : airp_documents
# Required: no
CHROMA_COLLECTION=airp_documents

# Local sentence-transformers model name for generating embeddings.
# Runs locally — no API cost. Model downloads on first run (~90MB).
# Type    : string
# Default : all-MiniLM-L6-v2 (fast, good quality, 384 dimensions)
# Options : all-MiniLM-L6-v2 | all-mpnet-base-v2 (slower, higher quality)
# Required: no
EMBEDDING_MODEL=all-MiniLM-L6-v2


# ── 7. Authentication (Clerk) ─────────────────────────────────────────────────

# Clerk secret key — used by the FastAPI backend to verify session tokens.
# Get it at: https://dashboard.clerk.com → your app → API Keys
# Format  : sk_live_... (production) or sk_test_... (development)
# Type    : string
# Required: yes (Phase 5 — FastAPI auth)
CLERK_SECRET_KEY=sk_test_replace-with-your-clerk-secret-key

# Clerk publishable key — used by the React frontend.
# Get it at: https://dashboard.clerk.com → your app → API Keys
# Format  : pk_live_... (production) or pk_test_... (development)
# Type    : string
# Required: yes (Phase 6 — React auth)
CLERK_PUBLISHABLE_KEY=pk_test_replace-with-your-clerk-publishable-key

# Clerk JWT issuer URL — used to verify token signatures.
# Format  : https://<your-clerk-domain>.clerk.accounts.dev
# Get it at: https://dashboard.clerk.com → your app → API Keys → JWT Templates
# Type    : string (URL)
# Required: yes (Phase 5 — FastAPI auth)
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev


# ── 8. External Data APIs ─────────────────────────────────────────────────────

# NewsAPI — fetches last 30 days of company news for the Sentiment Agent.
# Free tier: 100 requests/day. Cached for 1 hour in Redis.
# Get it at: https://newsapi.org/register
# Format  : 32-char hex string
# Type    : string
# Required: yes (Phase 1 — News Sentiment Agent)
NEWS_API_KEY=replace-with-your-newsapi-key

# Alpha Vantage — additional fundamentals and earnings data.
# Free tier: 25 requests/day. Use sparingly; Redis cache essential.
# Get it at: https://www.alphavantage.co/support/#api-key
# Format  : alphanumeric string
# Type    : string
# Required: yes (Phase 1 — Fundamental Analyst Agent)
ALPHA_VANTAGE_KEY=replace-with-your-alpha-vantage-key

# yFinance requires no API key — it is an unofficial Yahoo Finance scraper.
# Included here for documentation completeness. No value needed.
# Redis caching is still recommended to avoid rate limits.
# YFINANCE_API_KEY=not-required

# Screener.in — Indian stock peer comparison and financial ratios.
# Scraped directly (no official API). No key required.
# SCREENER_URL is documented here for reference.
# Type    : string (URL)
# Default : https://www.screener.in
SCREENER_BASE_URL=https://www.screener.in

# RBI data scraper base URL — used by the Macro Economist Agent.
# Type    : string (URL)
# Default : https://www.rbi.org.in
RBI_BASE_URL=https://www.rbi.org.in


# ── 9. Frontend (Vite) ────────────────────────────────────────────────────────
# IMPORTANT: All frontend variables MUST be prefixed with VITE_
# Only VITE_ prefixed variables are exposed to the browser bundle.
# Never put secret keys in VITE_ variables — they are public.

# Backend API URL — used by React Query API client.
# Local dev  : http://localhost:8000
# Production : https://your-backend.onrender.com
# Type    : string (URL, no trailing slash)
# Required: yes (Phase 6 — React frontend)
VITE_API_URL=http://localhost:8000

# Clerk publishable key for the React frontend.
# Same value as CLERK_PUBLISHABLE_KEY above — duplicated with VITE_ prefix
# because Vite only exposes variables with this prefix to the browser.
# Type    : string
# Required: yes (Phase 6 — React auth)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace-with-your-clerk-publishable-key

# App name displayed in the browser tab and header.
# Type    : string
# Default : AIRP
# Required: no
VITE_APP_NAME=AIRP

# Maximum analysis pipeline timeout in milliseconds shown in the UI.
# After this time the UI shows a timeout warning (does not cancel the job).
# Type    : integer (milliseconds)
# Default : 120000 (2 minutes — pipeline target is under 90 seconds)
# Required: no
VITE_ANALYSIS_TIMEOUT_MS=120000


# ── 10. Feature Flags ─────────────────────────────────────────────────────────
# Boolean flags to enable/disable features during development.
# Set to true/false. Evaluated as strings in Python (use == "true").

# Enable the multi-round debate loop. Set to false to run agents once
# without the adversarial debate round (faster, lower token cost for dev).
# Type    : boolean string
# Default : true
# Required: no
FEATURE_DEBATE_ENABLED=true

# Number of debate rounds. Ignored if FEATURE_DEBATE_ENABLED=false.
# Type    : integer
# Default : 2
# Required: no
DEBATE_ROUNDS=2

# Enable PDF generation via WeasyPrint. Set to false to return JSON only
# during early development when the PDF template isn't ready yet.
# Type    : boolean string
# Default : true
# Required: no
FEATURE_PDF_ENABLED=true

# Enable rate limiting on the FastAPI endpoints.
# Set to false in development to avoid hitting limits during testing.
# Type    : boolean string
# Default : true (always true in production)
# Required: no
FEATURE_RATE_LIMITING=true

# Maximum concurrent analysis jobs allowed per user.
# Type    : integer
# Default : 3
# Required: no
MAX_CONCURRENT_ANALYSES=3
