[flake8]
# Match black's line length exactly to avoid formatting conflicts
max-line-length = 88

# E203 — whitespace before ':' (black reformats slice notation this way)
# W503 — line break before binary operator (conflicts with black)
# D100-D107 — missing module/class/function docstrings at this stage
#              (re-enable once stubs are fleshed out in Phase 2+)
extend-ignore =
    E203,
    W503,
    D100,
    D101,
    D102,
    D103,
    D104,
    D105,
    D106,
    D107

# Directories to skip entirely
exclude =
    .git,
    __pycache__,
    .mypy_cache,
    .venv,
    venv,
    dist,
    build,
    *.egg-info,
    backend/tests/__pycache__,
    frontend/

# Per-file ignores for test files (assert statements, magic values OK in tests)
per-file-ignores =
    backend/tests/*:S101,S105,S106
    backend/tests/conftest.py:S101

# Enable optional bugbear and comprehension checks
select = E,W,F,B,C4

# B950 = line too long (bugbear's softer version; respects black's 88+margin)
extend-select = B950
max-doc-length = 120

# B008 flags function calls in parameter defaults as a general antipattern
# (mutable-default-argument footgun). FastAPI's Depends()/Query()/Body() etc.
# are specifically DESIGNED to be used this way -- FastAPI's dependency
# injection inspects route parameter defaults for these exact call objects.
# Whitelisting them here avoids a permanent false positive on every FastAPI
# route handler from T-046 (auth) onward.
#
# IMPORTANT: flake8-bugbear matches extend-immutable-calls against the
# literal text of the call expression in the AST -- it does NOT resolve
# imports. `import fastapi` + `fastapi.Depends(...)` matches the dotted
# entry below; `from fastapi import Depends` + bare `Depends(...)` does
# NOT match the dotted entry and needs the bare name listed separately.
# Both import styles appear across this codebase, so both forms are
# listed for every name to avoid this silently re-breaking per file.
# (See https://github.com/PyCQA/flake8-bugbear/issues/252.)
extend-immutable-calls =
    fastapi.Depends,
    Depends,
    fastapi.Query,
    Query,
    fastapi.Body,
    Body,
    fastapi.Path,
    Path,
    fastapi.Header,
    Header,
    fastapi.Cookie,
    Cookie,
    fastapi.Form,
    Form,
    fastapi.File,
    File,
    fastapi.Security,
    Security
