# =============================================================================
# AIRP — .gitignore
# Never commit secrets, build artefacts, or environment-specific files.
# =============================================================================


# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example        # .env.example IS committed — it documents all variables
*.pem
*.key
secrets/
.secret


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.Python
pip-wheel-metadata/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Profiling
*.prof


# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
.cache/
.parcel-cache/
.next/
.nuxt/
.vite/

# AIRP uses npm — exclude yarn and pnpm lock files
yarn.lock
pnpm-lock.yaml


# ── IDEs & editors ───────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json    # extensions.json is useful to commit
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini


# ── Docker ────────────────────────────────────────────────────────────────────
*.log
docker-compose.override.yml  # local overrides — never shared


# ── ChromaDB local storage ────────────────────────────────────────────────────
chroma_db/
chromadb/
chroma/


# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite3
*.db


# ── Generated / output ────────────────────────────────────────────────────────
reports/
generated/
# PDF memos are generated at runtime — not stored in the repo
*.pdf


# ── Jupyter (excluded — AIRP uses .py files, not notebooks) ──────────────────
.ipynb_checkpoints/
*.ipynb


# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
