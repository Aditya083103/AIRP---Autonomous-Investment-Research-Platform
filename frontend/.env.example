# frontend/.env.example
# Copy to .env.local for local overrides. All frontend vars MUST be
# prefixed with VITE_ to be exposed to the client bundle.

# Base URL of the AIRP backend API.
# Leave UNSET in local dev: requests use the relative "/api/v1" path, which
# the Vite dev proxy (vite.config.ts) forwards to http://localhost:8000.
# Set in production (e.g. Vercel project settings):
# VITE_API_BASE_URL=https://airp-api.onrender.com/api/v1
VITE_API_BASE_URL=http://localhost:8000

# Base URL of the AIRP auth endpoints (T-056). Separate from
# VITE_API_BASE_URL because backend/routers/auth.py mounts at "/auth",
# not under "/api/v1" (see backend/main.py's router registration).
# Leave UNSET in local dev: requests use the relative "/auth" path, which
# the Vite dev proxy (vite.config.ts) forwards to http://localhost:8000.
# Set in production (e.g. Vercel project settings):
# VITE_AUTH_BASE_URL=https://airp-api.onrender.com/auth
VITE_AUTH_BASE_URL=http://localhost:8000
